# Backend API
BACKEND_BASE_URL=http://localhost:8000/api

# Kakao
# https://developers.kakao.com > 내 애플리케이션 > 앱 키 > 네이티브 앱 키
KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key_here

# Naver Maps (Mobile SDK - Dynamic Map)
# https://console.ncloud.com > AI·NAVER API > Application > 인증 정보 > Client ID
# Secret은 앱에 포함하지 않음 (보안) — Reverse Geocoding은 백엔드에서 처리
NAVER_MAP_CLIENT_ID=your_naver_map_client_id_here
